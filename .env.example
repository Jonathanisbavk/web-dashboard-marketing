# Copia este archivo a .env.local y rellena los valores

# Clave de API de Google AI Studio (GRATIS — consíguela en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# URL de tu GitHub Pages (para restringir CORS a tu propio origen)
# Ejemplo: https://tu-usuario.github.io
ALLOWED_ORIGIN=https://tu-usuario.github.io
